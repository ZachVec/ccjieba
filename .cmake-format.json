{
  "line_width": 120,
  "tab_size": 4,
  "max_subgroups_hwrap": 2,
  "max_pargs_hwrap": 6,
  "keyword_case": "upper",
  "dangle_parens": false,
  "bullet_char": "*",
  "enum_char": ".",
  "line_ending": "unix",
  "command_case": "canonical",
  "separate_ctrl_name_with_space": false,
  "separate_fn_name_with_space": false,
  "enable_sort": true,
  "autosort": false
}
